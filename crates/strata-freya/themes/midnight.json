{
  "$schema": "./theme.schema.json",
  "id": "midnight",
  "name": "Midnight",
  "author": "Strata",
  "mode": "dark",
  "sheet": {
    "primary": "#4cc6ff",
    "secondary": "#a9e2ff",
    "tertiary": "#2ea6e0",
    "success": "#9fe6b4",
    "warning": "#ffa657",
    "error": "#ff8a8a",
